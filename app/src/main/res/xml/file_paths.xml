<?xml version="1.0" encoding="utf-8"?>
<!--
  File provider paths for sharing files (screenshots, exported data).
  Referenced in AndroidManifest.xml under <provider android:name="FileProvider">.
  Path: app/src/main/res/xml/file_paths.xml
-->
<paths>
    <!-- App internal files (cache) -->
    <cache-path name="shared_images" path="images/" />
    <!-- External downloads folder (for deal exports) -->
    <external-path name="external_files" path="." />
</paths>
